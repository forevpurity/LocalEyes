# Server runtime
# NODE_ENV gates Swagger UI (dev only) and the "secure" flag on auth cookies.
# NODE_ENV=development
# PORT=3000

DATABASE_URL=postgres://user:password@localhost:5432/localeyes
JWT_ACCESS_SECRET=change-me-to-a-random-64-char-hex-string
JWT_REFRESH_SECRET=change-me-to-another-random-64-char-hex-string
ACCESS_TOKEN_EXPIRES_IN=15m
ACCESS_TOKEN_MAX_AGE_MS=900000
REFRESH_TOKEN_EXPIRES_IN=7d
REFRESH_TOKEN_MAX_AGE_MS=604800000

# Client URL for constructing links in emails (e.g. password reset)
APP_URL=http://localhost:5173

# Cross-origin requests. Comma-separated list of allowed origins for the API and
# Socket.io. Leave unset to reflect the request origin (fine for local dev where
# the client is same-origin via the Vite proxy). Set this in production.
# CORS_ORIGIN=https://localeyes.vn,https://www.localeyes.vn

# Image storage. STORAGE_DRIVER is "local" (default) or "r2".
# When unset it defaults to "r2" if R2_BUCKET is present, otherwise "local".
# STORAGE_DRIVER=local
# UPLOAD_DIR=uploads            # local driver only — where files are written/served
# Cloudflare R2 (S3-compatible) — required when STORAGE_DRIVER=r2:
# R2_ACCOUNT_ID=your-cloudflare-account-id
# R2_ACCESS_KEY_ID=your-r2-access-key-id
# R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# R2_BUCKET=localeyes
# R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev   # bucket public URL or custom domain (no trailing slash)

# Email (SMTP) — required for password reset; skipped in dev when SMTP_HOST is unset.
# Resend (recommended): verify your domain at https://resend.com/domains (add the
# SPF/DKIM DNS records), then create an API key at https://resend.com/api-keys.
#   SMTP_USER is the literal word "resend"; SMTP_PASS is the API key (re_...).
#   MAIL_FROM must be an address on your verified domain.
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=resend
# SMTP_PASS=re_your_api_key_here
# MAIL_FROM="LocalEyes <noreply@yourdomain.com>"

# Rate limiting (all optional — defaults shown)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_GLOBAL_MAX=100
# RATE_LIMIT_AUTH_MAX=10
# RATE_LIMIT_REPORT_CREATE_MAX=5
# RATE_LIMIT_PASSWORD_RESET_MAX=3
