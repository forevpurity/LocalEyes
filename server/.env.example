DATABASE_URL=postgres://user:password@localhost:5432/localeyes
JWT_ACCESS_SECRET=change-me-to-a-random-64-char-hex-string
JWT_REFRESH_SECRET=change-me-to-another-random-64-char-hex-string
ACCESS_TOKEN_EXPIRES_IN=15m
ACCESS_TOKEN_MAX_AGE_MS=900000
REFRESH_TOKEN_EXPIRES_IN=7d
REFRESH_TOKEN_MAX_AGE_MS=604800000

# Client URL for constructing links in emails (e.g. password reset)
APP_URL=http://localhost:5173

# Email (SMTP) — required for password reset; skipped in dev when SMTP_HOST is unset
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM="LocalEyes <noreply@localeyes.vn>"

# Rate limiting (all optional — defaults shown)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_GLOBAL_MAX=100
# RATE_LIMIT_AUTH_MAX=10
# RATE_LIMIT_REPORT_CREATE_MAX=5
# RATE_LIMIT_PASSWORD_RESET_MAX=3
