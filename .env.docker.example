# Copy to `.env` (git-ignored) — docker compose reads it automatically.

# --- Public hostname (Caddy gets a TLS cert for this) ---
# Local testing: DOMAIN=localhost  (Caddy uses its own local CA, no email needed)
# Production:    DOMAIN=localeyes.vn  with DNS A-record pointing at this box
DOMAIN=localhost
ACME_EMAIL=

# --- App origin (must match how the browser reaches it, incl. https) ---
# Local:      https://localhost
# Production: https://localeyes.vn
CORS_ORIGIN=https://localhost
APP_URL=https://localhost

# --- Database credentials ---
# Defaults to localeyes/localeyes if unset. The db port is bound to the VPS's
# localhost only, but still use a strong password in production:
#   POSTGRES_PASSWORD=$(openssl rand -hex 16)
POSTGRES_USER=localeyes
POSTGRES_PASSWORD=localeyes
POSTGRES_DB=localeyes

# --- Secrets — generate each with:  openssl rand -hex 32 ---
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# --- Image storage (also used by `tools npm run db:seed`) ---
# "local" (default): the server writes/serves uploads under /app/uploads, backed
# by the uploads-data volume. The `tools` service mounts that same volume, so the
# demo seed's photos persist and are served at /uploads — no external setup needed.
STORAGE_DRIVER=local
#
# Production: switch to durable object storage that survives container/disk loss
# and works across multiple server instances. Set STORAGE_DRIVER=r2 and fill in
# the Cloudflare R2 (S3-compatible) credentials below.
# STORAGE_DRIVER=r2
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=localeyes
# Public bucket URL or custom domain, with no trailing slash.
# R2_PUBLIC_URL=
