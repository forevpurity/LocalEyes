# Copy to `.env` (git-ignored) — docker compose reads it automatically.

# --- Public hostname (Caddy gets a TLS cert for this) ---
# Local testing: DOMAIN=localhost  (Caddy uses its own local CA, no email needed)
# Production:    DOMAIN=localeyes.vn  with DNS A-record pointing at this box
DOMAIN=localhost
ACME_EMAIL=

# --- App origin (must match how the browser reaches it, incl. https) ---
# Local:      https://localhost
# Production: https://localeyes.vn
CORS_ORIGIN=https://localhost
APP_URL=https://localhost

# --- Database credentials ---
# Defaults to localeyes/localeyes if unset. The db port is bound to the VPS's
# localhost only, but still use a strong password in production:
#   POSTGRES_PASSWORD=$(openssl rand -hex 16)
POSTGRES_USER=localeyes
POSTGRES_PASSWORD=localeyes
POSTGRES_DB=localeyes

# --- Secrets — generate each with:  openssl rand -hex 32 ---
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
